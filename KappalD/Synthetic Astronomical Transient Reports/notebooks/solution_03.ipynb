import os
import random
import pandas as pd
import numpy as np
import torch
import torch.nn as nn
from torch.utils.data import Dataset, DataLoader
from torch.optim import AdamW
from transformers import AutoTokenizer, AutoModel, get_linear_schedule_with_warmup
from sklearn.preprocessing import LabelEncoder
from sklearn.metrics import f1_score
from sklearn.model_selection import KFold
from tqdm import tqdm

INPUT_DIR = "/kaggle/input/datasets/vsnihal/synthetic-astronomical-transient-reports"
OUTPUT_PATH = "/kaggle/working/submission.csv"

MODEL_NAME = "microsoft/deberta-v3-base" 
MAX_LEN = 130
BATCH_SIZE = 16
EPOCHS = 4
LEARNING_RATE = 2e-5
N_FOLDS = 4

CLEAN_COLS = ["transient_class", "host_environment", "spectral_regime"]
DERIVED_COLS = ["variability_pattern", "distance_bin", "energy_tier", "followup_protocol", "precursor_category"]
LABEL_COLS = CLEAN_COLS + DERIVED_COLS

def create_compositional_folds(df, n_folds=4):
    pairs = df[['transient_class', 'host_environment']].drop_duplicates().values.tolist()
    random.shuffle(pairs)
    
    kf = KFold(n_splits=n_folds)
    folds = []
    
    for train_idx, val_idx in kf.split(pairs):
        val_pairs = [pairs[i] for i in val_idx]
        val_mask = df.apply(lambda row: [row['transient_class'], row['host_environment']] in val_pairs, axis=1)
        
        train_df = df[~val_mask].reset_index(drop=True)
        val_df = df[val_mask].reset_index(drop=True)
        folds.append((train_df, val_df))
        
    return folds

class RobustTransientDataset(Dataset):
    def __init__(self, df, tokenizer, max_len, is_train=False):
        self.texts = df["narrative"].to_list()
        self.tokenizer = tokenizer
        self.max_len = max_len
        self.is_train = is_train
        self.has_labels = all(col in df.columns for col in LABEL_COLS)
        
        if self.has_labels:
            self.labels = df[LABEL_COLS].values
            self.entities = df[['transient_class', 'host_environment']].values
        else:
            self.labels = None

    def __len__(self):
        return len(self.texts)

    def __getitem__(self, item):
        text = str(self.texts[item])
        
        if self.is_train and self.has_labels:
            transient, host = self.entities[item]
            if random.random() < 0.10:
                text = text.replace(str(transient), self.tokenizer.mask_token)
            if random.random() < 0.10:
                text = text.replace(str(host), self.tokenizer.mask_token)

        inputs = self.tokenizer(
            text,
            add_special_tokens=True,
            max_length=self.max_len,
            padding="max_length",
            truncation=True,
            return_tensors="pt"
        )
        
        output = {
            "input_ids": inputs["input_ids"].flatten(),
            "attention_mask": inputs["attention_mask"].flatten()
        }
        
        if self.has_labels:
            output["labels"] = torch.tensor(self.labels[item], dtype=torch.long)
            
        return output

class MultiTaskTransformer(nn.Module):
    def __init__(self, model_name, num_classes_list):
        super(MultiTaskTransformer, self).__init__()
        # Explicitly enforce FP32 loading to prevent GradScaler conflicts
        self.model = AutoModel.from_pretrained(model_name, torch_dtype=torch.float32)
        self.drop = nn.Dropout(p=0.2)
        
        self.classifiers = nn.ModuleList([
            nn.Linear(self.model.config.hidden_size, num_classes)
            for num_classes in num_classes_list
        ])

    def forward(self, input_ids, attention_mask):
        outputs = self.model(
            input_ids=input_ids,
            attention_mask=attention_mask
        )
        pooled_output = outputs.last_hidden_state[:, 0, :]
        pooled_output = self.drop(pooled_output)
        
        logits = [classifier(pooled_output) for classifier in self.classifiers]
        return logits

def train_epoch(model, data_loader, loss_clean, loss_derived, optimizer, device, scheduler, scaler):
    model.train()
    total_loss = 0
    progress_bar = tqdm(data_loader, desc="Training", leave=False)

    for batch in progress_bar:
        input_ids = batch["input_ids"].to(device)
        attention_mask = batch["attention_mask"].to(device)
        labels = batch["labels"].to(device)

        optimizer.zero_grad()
        
        # Updated modern syntax for autocast
        with torch.amp.autocast('cuda'):
            logits = model(input_ids=input_ids, attention_mask=attention_mask)
            
            loss = 0
            for i, col in enumerate(LABEL_COLS):
                if col in DERIVED_COLS:
                    loss += loss_derived(logits[i], labels[:, i])
                else:
                    loss += loss_clean(logits[i], labels[:, i])
            
        scaler.scale(loss).backward()
        
        scaler.unscale_(optimizer)
        nn.utils.clip_grad_norm_(model.parameters(), max_norm=1.0)
        
        scaler.step(optimizer)
        scaler.update()
        scheduler.step()
        
        total_loss += loss.item()
        progress_bar.set_postfix({'loss': f"{loss.item():.4f}"})
        
    return total_loss / len(data_loader)

def evaluate(model, data_loader, device):
    model.eval()
    all_preds = [[] for _ in range(len(LABEL_COLS))]
    all_labels = [[] for _ in range(len(LABEL_COLS))]

    with torch.no_grad(), torch.amp.autocast('cuda'):
        for batch in tqdm(data_loader, desc="Evaluating", leave=False):
            input_ids = batch["input_ids"].to(device)
            attention_mask = batch["attention_mask"].to(device)
            labels = batch["labels"].numpy()
            
            logits = model(input_ids=input_ids, attention_mask=attention_mask)
            
            for i in range(len(LABEL_COLS)):
                preds = torch.argmax(logits[i], dim=1).cpu().numpy()
                all_preds[i].extend(preds)
                all_labels[i].extend(labels[:, i])
                
    derived_indices = [LABEL_COLS.index(col) for col in DERIVED_COLS]
    mf1_scores = [f1_score(all_labels[idx], all_preds[idx], average="macro", zero_division=0) for idx in derived_indices]
    return np.mean(mf1_scores)

def get_test_logits(model, data_loader, device, num_classes_list):
    model.eval()
    all_logits = [[] for _ in range(len(LABEL_COLS))]

    with torch.no_grad(), torch.amp.autocast('cuda'):
        for batch in tqdm(data_loader, desc="Inferencing", leave=False):
            input_ids = batch["input_ids"].to(device)
            attention_mask = batch["attention_mask"].to(device)
            
            logits = model(input_ids=input_ids, attention_mask=attention_mask)
            
            for i in range(len(LABEL_COLS)):
                probs = torch.softmax(logits[i], dim=1).cpu().numpy()
                all_logits[i].extend(probs)
                
    return [np.array(l) for l in all_logits]

def main():
    print("Step 1: Loading Data and Encoding Labels...")
    train_full = pd.read_csv(os.path.join(INPUT_DIR, "train.csv"))
    test_df = pd.read_csv(os.path.join(INPUT_DIR, "test.csv"))
    
    label_encoders = {}
    num_classes_list = []
    
    for col in LABEL_COLS:
        le = LabelEncoder()
        train_full[col] = le.fit_transform(train_full[col])
        label_encoders[col] = le
        num_classes_list.append(len(le.classes_))
        
    print(f"Step 2: Creating {N_FOLDS}-Fold Compositional Splits...")
    folds = create_compositional_folds(train_full, n_folds=N_FOLDS)
    tokenizer = AutoTokenizer.from_pretrained(MODEL_NAME)
    test_dataset = RobustTransientDataset(test_df, tokenizer, MAX_LEN, is_train=False)
    test_loader = DataLoader(test_dataset, batch_size=BATCH_SIZE, shuffle=False)
    device = torch.device("cuda" if torch.cuda.is_available() else "cpu")
    
    loss_fn_clean = nn.CrossEntropyLoss().to(device)
    loss_fn_derived = nn.CrossEntropyLoss(label_smoothing=0.10).to(device)
    
    scaler = torch.cuda.amp.GradScaler()
    
    ensemble_test_probs = [np.zeros((len(test_df), num_classes)) for num_classes in num_classes_list]
    
    for fold_idx, (train_df, val_df) in enumerate(folds):
        print(f"\n======================================")
        print(f"      STARTING FOLD {fold_idx + 1} OF {N_FOLDS}")
        print(f"======================================")
        
        train_dataset = RobustTransientDataset(train_df, tokenizer, MAX_LEN, is_train=True)
        val_dataset = RobustTransientDataset(val_df, tokenizer, MAX_LEN, is_train=False)
        train_loader = DataLoader(train_dataset, batch_size=BATCH_SIZE, shuffle=True)
        val_loader = DataLoader(val_dataset, batch_size=BATCH_SIZE, shuffle=False)
        
        model = MultiTaskTransformer(MODEL_NAME, num_classes_list).to(device)
        optimizer = AdamW(model.parameters(), lr=LEARNING_RATE, weight_decay=0.01)
        total_steps = len(train_loader) * EPOCHS
        scheduler = get_linear_schedule_with_warmup(optimizer, num_warmup_steps=int(0.1 * total_steps), num_training_steps=total_steps)
        
        best_val_score = 0
        best_model_path = f"best_model_fold_{fold_idx}.pth"
        
        for epoch in range(EPOCHS):
            train_loss = train_epoch(model, train_loader, loss_fn_clean, loss_fn_derived, optimizer, device, scheduler, scaler)
            val_score = evaluate(model, val_loader, device)
            print(f"Fold {fold_idx+1} | Epoch {epoch + 1}/{EPOCHS} | Train Loss: {train_loss:.4f} | Val F1: {val_score:.4f}")
            
            if val_score > best_val_score:
                best_val_score = val_score
                torch.save(model.state_dict(), best_model_path)
                
        print(f"Running test inference for Fold {fold_idx+1}...")
        model.load_state_dict(torch.load(best_model_path))
        fold_probs = get_test_logits(model, test_loader, device, num_classes_list)
        
        for i in range(len(LABEL_COLS)):
            ensemble_test_probs[i] += fold_probs[i] / N_FOLDS
            
    print("\n======================================")
    print("Step 3: Generating Ensemble Predictions...")
    submission_df = pd.DataFrame({'id': test_df['id']})
    
    for i, col in enumerate(LABEL_COLS):
        final_preds = np.argmax(ensemble_test_probs[i], axis=1)
        submission_df[col] = label_encoders[col].inverse_transform(final_preds)
        
    submission_cols = ["id"] + LABEL_COLS
    submission_df = submission_df[submission_cols]
    
    os.makedirs(os.path.dirname(OUTPUT_PATH), exist_ok=True)
    submission_df.to_csv(OUTPUT_PATH, index=False)
    print(f"Finished. Final ensembled predictions saved to {OUTPUT_PATH}")

if __name__ == "__main__":
    main()
